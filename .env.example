# GEMINI_API_KEY: Required for Gemini API calls.
# Get a key at https://aistudio.google.com/apikey and paste it here, then
# copy this file to .env (which is gitignored). Restart the dev server.
GEMINI_API_KEY="your-gemini-api-key"

# Optional: override the default 3000 port.
# PORT=3100

# Optional: set NODE_ENV=production for the built `npm start` flow.
# Otherwise `npm run dev` runs Vite in middleware mode for HMR.
# NODE_ENV=production
